{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/tool-",
        "--extensions-dir=${env:USERPROFILE}\\.vscode\\extensions"
      ],
      "outFiles": [
        "${workspaceFolder}/tool-/out/**/*.js"
      ],
      "preLaunchTask": "npm: compile"
    }
  ]
}
